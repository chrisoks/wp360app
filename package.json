{
  "name": "workpilot360-pwa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "check": "npm run check:regression && npm run check:mojibake && npm run check:typescript && npm run check:diff",
    "check:regression": "node scripts/check-regression.mjs",
    "check:mojibake": "node scripts/check-mojibake.mjs",
    "check:typescript": "tsc -b",
    "check:diff": "node scripts/check-diff.mjs",
    "safety:before": "node scripts/safety-snapshot.mjs before",
    "safety:after": "node scripts/safety-snapshot.mjs after"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "vite": "^7.2.4",
    "typescript": "^5.9.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "lucide-react": "^0.554.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  }
}
